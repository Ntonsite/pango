# Copy to .env and fill in real values for your environment.
# ENVIRONMENT=production disables demo-user seeding and requires a strong SECRET_KEY.
ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://pango_user:pango_password@postgres:5432/pango_db
REDIS_URL=redis://redis:6379/0

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-strong-random-secret

# Comma-separated list of allowed frontend origins.
# e.g. http://your-server-ip or https://your-domain.com in production.
CORS_ORIGINS=http://localhost:5173,http://localhost
